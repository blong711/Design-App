# ─── MongoDB ──────────────────────────────────────────────
# For Docker Compose:
MONGODB_URL=mongodb://database:27017
# For local dev:
# MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=design_manager

# ─── JWT Security ─────────────────────────────────────────
# CHANGE THIS in production! Generate with: openssl rand -hex 32
SECRET_KEY=YOUR_SUPER_SECRET_KEY_PLEASE_CHANGE_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ─── AWS S3 ───────────────────────────────────────────────
# All uploads go to S3. Folder structure in bucket:
#   avatars/{user_id}/{uuid}.ext    — user profile pictures
#   tickets/{user_id}/{uuid}.ext    — ticket reference images
#   results/{user_id}/{uuid}.ext    — designer final deliverables
#
# Bucket policy: set public-read on the above prefixes so URLs are accessible.
# Example bucket policy (allow public GET):
#   { "Effect": "Allow", "Principal": "*", "Action": "s3:GetObject",
#     "Resource": "arn:aws:s3:::YOUR_BUCKET/*" }
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=design-manager-uploads
# ─── Email Settings (SMTP or Gmail API) ────────────────────
# Option 1: Use SMTP (Less secure, easier dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="Design Manager"

# Option 2: Use Gmail API (Secure, recommended for GCP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SENDER_EMAIL=  # Your Gmail address used for sending

FRONTEND_URL=http://localhost:3000